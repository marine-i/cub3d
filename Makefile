#Objects

OBJ_DIR      = obj
OBJS         = $(addprefix $(OBJ_DIR)/, $(SRCS:.c=.o))
OBJS 		 = $(patsubst $(SRC_DIR)%.c, $(OBJ_DIR)%.o, $(SRCS_WITH_SRCDIR))

DEPS         = $(OBJS:.o=.d)

